---
import { Image } from "astro:assets";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import BtnLink from "../shared/BtnLink.astro";
import GradiantText from "../shared/GradiantText.astro";

import mapsBeforeAfter from "../../../public/images/v1-feedback/before-after-maps.png";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class=`relative overflow-hidden pt-32 lg:pt-36 bg-slate-50/65 ${className}`>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_16%_20%,rgba(191,219,254,0.55),transparent_24%),radial-gradient(circle_at_78%_12%,rgba(255,255,255,0.92),transparent_28%)]"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(#d3dce8_1px,transparent_1px)] [background-size:20px_20px] opacity-65"></div>
  <Container className={"flex flex-col lg:flex-row gap-10 lg:gap-12 items-center"}>
    <div
      class="relative flex flex-col items-center text-center lg:text-left lg:py-7 xl:py-8
        lg:items-start lg:max-w-none max-w-3xl mx-auto lg:mx-0 lg:flex-1 lg:w-1/2"
    >
      <h1
        class="text-4xl/tight sm:text-5xl/tight md:text-6xl/tight xl:text-7xl/tight
             font-bold text-heading-1 tracking-tight"
      >
        Become the <GradiantText>#1 tradie</GradiantText> in your area.
      </h1>
      <Paragraph className="mt-8 text-lg md:text-xl text-heading-3">
        Your phone ringing with jobs you actually want. No ad spend. No chasing
        leads. Just your business showing up first on Google Maps, first on
        Google Search, with more 5-star reviews than anyone else in your area —
        every single month.
      </Paragraph>

      <div class="mt-10 w-full flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row gap-4 lg:justify-start justify-center">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-[#172554] transition-all duration-300 ease-in-out text-center shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-1"
          >
            Book a Strategy Call
          </a>
          <BtnLink
            text="Get Your Free Local Ranking Audit"
            href="/v1/thank-you"
            variant="secondary"
            className="text-center font-semibold hover:bg-slate-50 hover:scale-105 transition-all duration-300"
          />
        </div>
      </div>
    </div>

    <div
      class="flex flex-1 lg:w-1/2 relative lg:max-w-none lg:mx-0 mx-auto max-w-3xl justify-center lg:justify-end"
    >
      <div class="relative w-full max-w-[38rem]">
        <div class="absolute -inset-8 rounded-[2.5rem] bg-gradient-to-br from-sky-200/60 via-primary/10 to-emerald-100/40 blur-3xl"></div>
        <div class="absolute left-8 top-10 hidden sm:flex items-center gap-3 rounded-2xl border border-white/80 bg-white/90 px-4 py-3 shadow-[0_22px_55px_rgba(15,23,42,0.12)] backdrop-blur">
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 shadow-inner shadow-emerald-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4m10-8 6 8-6 8" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Map Lift</p>
            <p class="mt-1 text-sm font-semibold text-slate-900">From invisible to top-of-map visibility</p>
          </div>
        </div>
        <div class="absolute -right-2 bottom-10 hidden sm:block rounded-[1.75rem] border border-slate-200/80 bg-white/95 p-5 shadow-[0_30px_70px_rgba(37,99,235,0.15)] backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Typical outcome</p>
          <div class="mt-3 flex items-end gap-4">
            <div>
              <p class="text-3xl font-bold text-slate-900">4.9</p>
              <p class="text-sm text-slate-500">Average rating signal</p>
            </div>
            <div class="h-16 w-px bg-slate-200"></div>
            <div>
              <p class="text-3xl font-bold text-slate-900">Top 3</p>
              <p class="text-sm text-slate-500">Google Maps placement</p>
            </div>
          </div>
        </div>
        <div class="absolute inset-x-[18%] bottom-4 h-12 rounded-full bg-slate-900/12 blur-3xl"></div>
        <Image
          src={mapsBeforeAfter}
          alt="Google Maps ranking transformation — before and after Local Leader"
          class="relative w-full h-auto object-contain drop-shadow-[0_34px_70px_rgba(15,23,42,0.18)]"
        />
      </div>
    </div>
  </Container>
</section>
