---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

const testimonials = [
  {
    quote:
      "Finally someone who speaks my language. No jargon, no fluff. Just results.",
    name: "Jake R.",
    trade: "Concreter",
    location: "Western Sydney, NSW",
    reviewAge: "6 days ago",
  },
  {
    quote:
      "Within 8 weeks my phone was ringing with jobs I didn't have to quote against three other blokes for.",
    name: "Dave M.",
    trade: "Electrician",
    location: "Newcastle, NSW",
    reviewAge: "2 weeks ago",
  },
  {
    quote:
      "We went from 14 Google reviews to 52 in four months. My phone rings before 8am most mornings now.",
    name: "Chris W.",
    trade: "Landscaper",
    location: "Melbourne, VIC",
    reviewAge: "3 weeks ago",
  },
  {
    quote:
      "I'd been burned by two agencies before. These guys just showed me the data, told me what they'd do, and did it. No BS.",
    name: "Sarah T.",
    trade: "Plumber",
    location: "Gold Coast, QLD",
    reviewAge: "1 month ago",
  },
];

const stars = Array.from({ length: 5 });

export interface Props {
  className?: string;
  audience?: "tradie" | "business";
}

const { className, audience = "tradie" } = Astro.props;
---

<section id="reviews" class=`${className}`}>
  <Container className="space-y-12">
    <div class="mx-auto max-w-3xl space-y-4 text-center">
      <Title>
        {audience === "tradie" ? "Tradies" : "Businesses"} who stopped{" "}
        <GradiantText>chasing work</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        Real local proof from Australian operators already winning quality jobs from Google.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        testimonials.map((t) => (
          <div class="group flex flex-col justify-between rounded-[1.75rem] border border-slate-200/80 bg-white p-6 shadow-[0_24px_55px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
            <div>
              <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-700">
                    {t.name.charAt(0)}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-heading-1">{t.name}</p>
                    <p class="text-xs text-heading-3">{t.trade} · {t.location}</p>
                  </div>
                </div>
              </div>

              <div class="mt-5 flex items-center justify-between gap-3">
                <div class="flex items-center gap-1">
                  {
                    stars.map(() => (
                      <svg class="h-4 w-4 text-[#fbbc05]" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.363-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81H7.03a1 1 0 00.95-.69l1.07-3.292z" />
                      </svg>
                    ))
                  }
                </div>
                <p class="text-xs font-medium text-slate-400">{t.reviewAge}</p>
              </div>

              <p class="mt-5 text-[0.98rem] font-medium leading-relaxed text-heading-2">
                {t.quote}
              </p>
            </div>

          </div>
        ))
      }
    </div>
  </Container>
</section>
