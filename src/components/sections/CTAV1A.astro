---
import Container from "../shared/Container.astro";
import GradiantText from "../shared/GradiantText.astro";
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  className?: string;
  audience?: "tradie" | "business" | "agency";
  thankYouPath?: string;
}

const { className, audience = "tradie", thankYouPath = "/thank-you" } = Astro.props;
---

<section id="cta" class=`pb-20 ${className}`}>
  <Container>
    <div
      class="relative w-full rounded-2xl bg-gradient-to-br from-slate-100 to-zinc-200 px-6 py-8 md:px-8 md:py-10"
    >
      <div class="relative mx-auto max-w-xl text-center md:max-w-2xl">
        <h1
          class="text-3xl/tight font-bold text-heading-1 sm:text-4xl/tight md:text-5xl/tight"
        >
          Ready to
          <GradiantText>own your area?</GradiantText>
        </h1>
        <Paragraph className="pt-8 font-medium">
          {audience === "tradie"
            ? "Most tradies see movement in 30 days. Start with a free look at where you stand on Google."
            : audience === "agency"
            ? "Most agents see movement in 30 days. Start with a free look at where you stand for vendor-intent searches in your suburb."
            : "Most local businesses see movement in 30 days. Start with a free look at where you stand on Google."}
        </Paragraph>
        <div class="mx-auto flex max-w-md flex-col items-center gap-6 pt-10 sm:max-w-xl">
          <a
            href="https://calendly.com/reece-localleader/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full rounded-full bg-primary px-10 py-4 text-center text-xl font-bold text-white shadow-xl shadow-primary/30 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:bg-[#172554] hover:shadow-primary/50 sm:w-auto"
          >
            Book Your Free Strategy Call
          </a>
          <a
            href={thankYouPath}
            class="font-medium text-heading-3 transition hover:text-primary hover:underline"
          >
            Open the booking page for your free strategy call &amp; local ranking walkthrough →
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
