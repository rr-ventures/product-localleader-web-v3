---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;

const coreIncludes = [
  "Google Maps top 3 positioning",
  "First page of Google Search",
  "5-star review engine",
  "Google Business Profile management",
  "Local citation building",
  "Monthly reporting — plain English",
  "Competitor gap analysis",
  "Priority support",
  "No ad spend required",
  "No lock-in contracts",
];

const brandingIncludes = [
  "Website design and refresh support",
  "Logo refinements and brand assets",
  "Social media post design",
  "Graphic design collateral",
  "Email signature setup",
  "Professional business email setup",
];
---

<section id="pricing" class=`${className}`>
  <Container className="space-y-12">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title>
        Simple, <GradiantText>transparent pricing</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        One flat monthly price. No hidden extras. No ad budget on top.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div
        class="relative flex flex-col overflow-hidden rounded-3xl bg-slate-900 p-10 text-white shadow-2xl shadow-slate-900/20"
      >
        <div class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-[#1A73E8] via-blue-400 to-[#34A853]"></div>
        <div class="absolute -top-24 -right-24 h-48 w-48 rounded-full bg-blue-500 opacity-20 blur-3xl"></div>

        <div class="relative z-10">
          <div class="flex flex-wrap items-start justify-between gap-5">
            <div>
              <div class="inline-flex items-center gap-2 rounded-full border border-blue-400/25 bg-blue-500/12 px-4 py-2 text-xs font-bold uppercase tracking-[0.24em] text-blue-200">
                <span class="h-2 w-2 rounded-full bg-blue-300"></span>
                Early Bird Offer
              </div>
              <h3 class="mt-5 flex items-center gap-3 text-3xl font-bold text-white">
                <svg class="h-7 w-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Local Leader Package
              </h3>
              <p class="mt-3 max-w-md text-sm text-slate-400">
                Everything you need to become the obvious choice in your local area on Google.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-right">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Founding rate</p>
              <p class="mt-2 text-sm font-medium text-slate-300">Keep this rate while you stay on</p>
            </div>
          </div>

          <div class="mt-8 flex items-end gap-2">
            <span class="text-6xl font-bold tracking-tight text-white">$500</span>
            <span class="mb-2 font-medium text-slate-400">/mo</span>
          </div>
          <p class="mt-2 text-sm text-slate-500"><span class="line-through">$2,000/month</span> · AUD · No lock-in after initial 3-month commitment</p>
        </div>

        <div class="relative z-10 mt-10">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full rounded-full bg-white px-6 py-4 text-center font-bold text-slate-900 transition-all duration-300 hover:-translate-y-1 hover:bg-slate-50 hover:shadow-xl"
          >
            Claim Early Bird Pricing
          </a>
        </div>

        <ul class="relative z-10 mt-10 flex flex-col gap-4">
          {
            coreIncludes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <svg class="h-5 w-5 flex-shrink-0 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative flex flex-col rounded-3xl border border-slate-200 bg-white/90 p-8 shadow-[0_22px_55px_rgba(15,23,42,0.08)] backdrop-blur">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-400">Custom Scope</p>
            <h3 class="mt-4 text-2xl font-bold text-heading-1">Brand & Authority Package</h3>
            <p class="mt-3 text-sm leading-relaxed text-heading-3">
              For businesses that also want their brand presentation to match the quality of the leads they are chasing.
            </p>
          </div>
          <div class="rounded-2xl bg-slate-100 px-4 py-3 text-right">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Pricing</p>
            <p class="mt-1 text-sm font-semibold text-slate-900">Custom quote</p>
          </div>
        </div>

        <ul class="mt-8 flex flex-col gap-4">
          {
            brandingIncludes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-heading-3">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>

        <div class="mt-8 rounded-[1.5rem] bg-slate-50 px-5 py-4 text-sm leading-relaxed text-heading-3">
          Ideal for operators who want Local Leader to help with the broader trust stack as well, from site polish to branded assets.
        </div>

        <a
          href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center justify-center rounded-full border border-slate-200 px-6 py-4 text-center font-semibold text-slate-900 transition-all duration-300 hover:-translate-y-0.5 hover:border-slate-300 hover:bg-slate-50"
        >
          Ask About Custom Pricing
        </a>
      </div>
    </div>
  </Container>
</section>
