---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import BtnLink from "../shared/BtnLink.astro";
import GradiantText from "../shared/GradiantText.astro";

export interface Props {
  className?: string;
  audience?: "tradie" | "business";
  thankYouPath?: string;
}

const {
  className,
  audience = "tradie",
  thankYouPath = "/thank-you",
} = Astro.props;
---

<section class=`relative overflow-hidden bg-slate-50/70 pt-32 lg:pt-36 ${className}`}>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_16%_20%,rgba(191,219,254,0.55),transparent_24%),radial-gradient(circle_at_78%_12%,rgba(255,255,255,0.92),transparent_28%)]"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(#d3dce8_1px,transparent_1px)] [background-size:20px_20px] opacity-65"></div>
  <Container className={"flex flex-col items-center gap-12 lg:flex-row lg:gap-10 xl:gap-14"}>
    <div
      class="relative mx-auto flex max-w-3xl flex-col items-center text-center lg:mx-0 lg:w-[48%] lg:max-w-none lg:items-start lg:py-7 lg:text-left xl:py-8"
    >
      <h1
        class="text-4xl/tight font-bold tracking-tight text-heading-1 sm:text-5xl/tight md:text-6xl/tight xl:text-7xl/tight"
      >
        Become the <GradiantText>#1 {audience === "tradie" ? "tradie" : "service provider"}</GradiantText> in your area.
      </h1>
      <Paragraph className="mt-8 text-lg text-heading-3 md:text-xl">
        {audience === "tradie"
          ? "The tradies in your area who are booked out aren't booked out because they do better work. They're just easier to find when someone needs the job done."
          : "The businesses in your area that are booked out aren't booked out because they do better work. They're just easier to find when someone needs the job done."}
      </Paragraph>

      <div class="mt-10 flex w-full flex-col items-center gap-4 lg:items-start">
        <div class="flex w-full flex-col items-center justify-center gap-4 sm:flex-row lg:justify-start">
          <a
            href="https://calendly.com/reece-localleader/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full rounded-full bg-primary px-8 py-4 text-center text-lg font-bold text-white shadow-lg shadow-primary/30 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:bg-[#172554] hover:shadow-primary/50 sm:w-auto"
          >
            Book a Strategy Call
          </a>
          <BtnLink
            text="Get Your Free Local Ranking Audit"
            href={thankYouPath}
            variant="secondary"
            className="inline-flex w-full items-center justify-center text-center font-semibold transition-all duration-300 hover:scale-105 hover:bg-slate-50 sm:w-auto"
          />
        </div>
      </div>
    </div>

    <div
      class="relative flex flex-1 justify-center lg:w-[52%] lg:justify-end"
    >
      <div class="relative w-full max-w-[44rem] lg:max-w-[46rem]">
        <div class="absolute -inset-x-2 top-8 h-[72%] rounded-[3rem] bg-gradient-to-br from-sky-200/55 via-blue-100/25 to-emerald-100/35 blur-3xl"></div>
        <div class="relative z-10 grid items-center gap-4 sm:grid-cols-[1fr_auto_1fr]">
          <article class="rounded-3xl border border-slate-200/80 bg-white p-4 shadow-[0_24px_55px_rgba(15,23,42,0.12)] sm:p-5">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Before</p>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-slate-500">Low visibility</span>
            </div>
            <div class="mt-4 rounded-2xl border border-slate-100 bg-slate-50/85 p-3">
              <div class="h-24 rounded-xl bg-[linear-gradient(140deg,#e2e8f0_0%,#cbd5e1_100%)]"></div>
              <div class="mt-3 flex items-center justify-between">
                <p class="text-sm font-semibold text-slate-800">Gold Coast Plumbing Co</p>
                <p class="text-xs font-medium text-slate-500">3.2 ★</p>
              </div>
              <p class="mt-1 text-xs text-slate-500">8 reviews</p>
            </div>
          </article>

          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-50 to-white text-primary shadow-[0_12px_35px_rgba(37,99,235,0.25)]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16m-7-7 7 7-7 7" />
            </svg>
          </div>

          <article class="rounded-3xl border border-slate-200/80 bg-white p-4 shadow-[0_24px_55px_rgba(15,23,42,0.12)] sm:p-5">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">After</p>
              <span class="rounded-full bg-emerald-50 px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-emerald-700">Top results</span>
            </div>
            <div class="mt-4 rounded-2xl border border-slate-100 bg-white p-3">
              <div class="h-24 rounded-xl bg-[linear-gradient(140deg,#bfdbfe_0%,#d1fae5_100%)]"></div>
              <div class="mt-3 flex items-center justify-between">
                <p class="text-sm font-semibold text-slate-900">Gold Coast Plumbing Co</p>
                <p class="text-xs font-semibold text-emerald-700">4.9 ★</p>
              </div>
              <p class="mt-1 text-xs font-medium text-slate-600">(07) 3123 4587 · 187 reviews</p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </Container>
</section>
