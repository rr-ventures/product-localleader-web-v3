---
import Container from "../shared/Container.astro";
import { solutions } from "../../utils/data";

type SolutionsProps = {
  title: string;
  painPoint: string;
  agitatepainPoint: string;
  solution: string;
};

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="how-it-works" class=`flex flex-col ${className}`}>
  <Container>
    <div class="mx-auto max-w-3xl space-y-4 px-6 pb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-heading-1 sm:text-4xl md:text-5xl">
        Three things that make you <span class="bg-gradient-to-r from-[#1A73E8] via-blue-500 to-[#34A853] bg-clip-text text-transparent">the obvious choice</span>
      </h2>
      <p class="text-heading-3 md:text-lg">
        Every tradie who gets serious about Google wins in the same three places. Here&apos;s exactly what we do.
      </p>
    </div>

    <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-3">
      {
        solutions.map((solution: SolutionsProps, index: number) => {
          return (
            <article class="group relative overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/95 p-8 shadow-[0_22px_55px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_75px_rgba(15,23,42,0.12)]">
              <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#1A73E8] via-blue-400 to-[#34A853]"></div>
              <div class="absolute -right-10 top-0 h-28 w-28 rounded-full bg-blue-100/70 blur-3xl"></div>

              <div class="relative">
                <div class="flex items-start justify-between gap-5">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-lg font-bold text-white shadow-lg shadow-slate-900/15">
                    {index + 1}
                  </div>
                  <div class="rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.18em] text-primary">
                    Pillar {index + 1}
                  </div>
                </div>

                <h3 class="mt-6 text-2xl font-bold text-heading-1">
                  {solution.title}
                </h3>

                <div class="mt-6 rounded-[1.5rem] border border-slate-100 bg-slate-50/80 p-5">
                  <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-400">
                    What most tradies are dealing with
                  </p>
                  <p class="mt-3 text-base font-semibold leading-relaxed text-heading-1">
                    {solution.painPoint}
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-heading-3">
                    {solution.agitatepainPoint}
                  </p>
                </div>

                <div class="mt-6 rounded-[1.5rem] bg-slate-950 px-5 py-5 text-white shadow-lg shadow-slate-900/10">
                  <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-blue-200">
                    How Local Leader fixes it
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-slate-100">
                    {solution.solution}
                  </p>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </Container>
</section>
