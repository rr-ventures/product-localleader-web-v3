---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import GradiantText from "../shared/GradiantText.astro";

export interface Props {
  className?: string;
  audience?: "tradie" | "business";
}

const { className, audience = "tradie" } = Astro.props;

const coreIncludes = [
  "Google Maps top 3 positioning",
  "First page of Google Search",
  "5-star review engine",
  "Google Business Profile management",
  "Local citation building",
  "Monthly reporting in plain English",
  "Competitor gap analysis",
  "Priority support",
  "No ad spend required",
  "No lock-in contracts",
];

const brandingIncludes = [
  "Website, logo & brand design/refresh",
  "Social posts and advertising templates",
  "Quote, proposal & email templates",
  "Review, testimonial & trust assets",
  "Newsletters & email lead nurturing",
  "Vehicle signage & physical branding",
  "Flyers, brochures & print materials",
];
---

<section id="pricing" class=`${className}`}>
  <Container className="space-y-12">
    <div class="mx-auto max-w-3xl space-y-4 text-center">
      <Title>
        Simple, <GradiantText>transparent pricing</GradiantText>
      </Title>
      <p class="text-heading-3 md:text-lg">
        One flat monthly price. Clear deliverables. No ad budget on top.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div
        class="relative flex flex-col overflow-hidden rounded-3xl border border-blue-100 bg-[linear-gradient(145deg,#1e3a8a_0%,#2563eb_46%,#1d4ed8_100%)] p-10 text-white shadow-[0_28px_70px_rgba(37,99,235,0.28)]"
      >
        <div class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-sky-200 via-white/90 to-emerald-200"></div>
        <div class="absolute -top-24 -right-24 h-52 w-52 rounded-full bg-white/18 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-12 h-48 w-48 rounded-full bg-sky-200/20 blur-3xl"></div>

        <div class="relative z-10">
          <div class="flex flex-wrap items-start justify-between gap-5">
            <div>
              <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.24em] text-blue-50">
                <span class="h-2 w-2 rounded-full bg-emerald-300"></span>
                Early Bird Offer
              </div>
              <h3 class="mt-5 text-3xl font-bold text-white">
                Local Leader Package
              </h3>
              <p class="mt-3 max-w-md text-sm text-blue-50/90">
                Everything you need to become the obvious choice in your local area on Google.
              </p>
            </div>
            <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-right">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-100/75">Founding rate</p>
              <p class="mt-2 text-sm font-medium text-white">Keep this rate while you stay on</p>
            </div>
          </div>

          <div class="mt-8 flex items-end gap-2">
            <span class="text-6xl font-bold tracking-tight text-white">$499</span>
            <span class="mb-2 font-medium text-blue-50/85">/mo</span>
          </div>
          <p class="mt-2 text-sm text-blue-100/85">
            <span class="line-through">$1,499/month</span> · AUD · No lock-in month-to-month
          </p>
        </div>

        <div class="relative z-10 mt-10">
          <a
            href="https://calendly.com/reece-localleader/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full rounded-full bg-white px-6 py-4 text-center font-bold text-slate-900 transition-all duration-300 hover:-translate-y-1 hover:bg-slate-50 hover:shadow-xl"
          >
            Claim Early Bird Pricing
          </a>
        </div>

        <ul class="relative z-10 mt-10 flex flex-col gap-4">
          {
            coreIncludes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-white/95">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-sky-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-medium">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative flex flex-col rounded-3xl border border-slate-200/90 bg-white/88 p-8 shadow-[0_16px_36px_rgba(15,23,42,0.06)] backdrop-blur">
        <div class="flex flex-wrap items-start justify-between gap-5">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.2em] text-slate-500">
              Professional Package
            </div>
            <h3 class="text-2xl font-bold text-heading-1">Become the most professional {audience === "tradie" ? "tradie business" : "business"} in your area</h3>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-heading-3">
              For businesses that want their brand presentation, trust signals, and follow-up assets to match the quality of the leads they want to win.
            </p>
          </div>
          <div class="rounded-2xl bg-slate-100 px-4 py-3 text-right">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Pricing</p>
            <p class="mt-2 text-sm font-semibold text-slate-900">Tailored to your business</p>
          </div>
        </div>

        <ul class="mt-8 flex flex-col gap-4">
          {
            brandingIncludes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-heading-2">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-medium">{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 rounded-[1.5rem] bg-slate-50/90 px-5 py-4 text-sm leading-relaxed text-heading-2">
          Ideal for operators who want Local Leader to sharpen the full trust stack around the rankings work, from the first impression right through to follow-up assets.
        </div>

        <a
          href="https://calendly.com/reece-localleader/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-4 text-center font-semibold text-slate-900 transition-all duration-300 hover:-translate-y-0.5 hover:border-slate-300 hover:bg-slate-50"
        >
          Let&apos;s Talk
        </a>
      </div>
    </div>
  </Container>
</section>
