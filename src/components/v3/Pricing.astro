<section class="py-24 px-6 md:px-12 bg-white border-y border-slate-200">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-serif font-medium text-slate-900 mb-6">Simple, transparent pricing.</h2>
      <p class="text-lg text-slate-600">What's your average job worth? One extra customer from Google more than covers it.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Tier 1: Local Leader Package -->
      <div class="bg-slate-900 rounded-3xl p-8 md:p-12 text-white shadow-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 bg-yellow-400 text-yellow-900 text-xs font-bold px-4 py-1 rounded-bl-lg uppercase tracking-wide">
          Early Bird Offer
        </div>
        
        <h3 class="text-2xl font-serif font-medium mb-2">Local Leader Package</h3>
        <p class="text-slate-400 mb-6">Everything above. One price. No surprises.</p>
        
        <div class="mb-8">
          <div class="flex items-end gap-2">
            <span class="text-5xl font-medium tracking-tight">$500</span>
            <span class="text-slate-400 mb-1">/month</span>
          </div>
          <p class="text-sm text-slate-400 mt-2 line-through decoration-slate-600">Regularly $2,000/month</p>
        </div>
        
        <ul class="space-y-4 mb-10 flex-grow">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Top of Google Maps ranking management</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">First Page of Google SEO optimisation</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Automated 5-Star Review Engine</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">No ad spend required</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Month-to-month after initial 3 months</span>
          </li>
        </ul>
        
        <div class="space-y-3 mt-auto">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            class="block w-full text-center px-8 py-4 text-base font-medium text-slate-900 bg-white rounded-full hover:bg-slate-100 transition-colors"
          >
            Claim Early Bird Pricing
          </a>
          <p class="text-xs text-center text-slate-400">Limited spots. Founding client pricing. You keep that rate as long as you stay.</p>
        </div>
      </div>

      <!-- Tier 2: Brand & Authority Package -->
      <div class="bg-slate-50 rounded-3xl p-8 md:p-12 border border-slate-200 flex flex-col">
        <h3 class="text-2xl font-serif font-medium text-slate-900 mb-2">Brand & Authority Package</h3>
        <p class="text-slate-600 mb-6">For businesses that need a complete digital overhaul.</p>
        
        <div class="mb-8">
          <span class="text-3xl font-medium tracking-tight text-slate-900">Custom Scope</span>
        </div>
        
        <ul class="space-y-4 mb-10 flex-grow">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-600">Everything in Local Leader Package</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-600">Website design & refresh</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-600">Logos & branding assets</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-600">Social media post design</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-600">Professional business email setup</span>
          </li>
        </ul>
        
        <div class="mt-auto">
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            class="block w-full text-center px-8 py-4 text-base font-medium text-slate-900 bg-white border border-slate-200 rounded-full hover:bg-slate-50 transition-colors"
          >
            Discuss Custom Package
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
