---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-400 py-12 px-6 md:px-12 border-t border-slate-800">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-2">
      <img src="/images/v3-logo.jpg" alt="Local Leader Logo" class="h-8 w-auto grayscale opacity-50" />
    </div>
    
    <div class="text-sm">
      &copy; {currentYear} Local Leader. All rights reserved.
    </div>
    
    <div class="flex gap-6 text-sm">
      <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
      <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
    </div>
  </div>
</footer>
