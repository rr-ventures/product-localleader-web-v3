<section id="pricing" class="py-24 bg-[#fbfaf7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-4xl font-extrabold text-slate-900 mb-6">
        Simple, transparent pricing.
      </h2>
      <p class="text-xl text-slate-600">
        What's your average job worth? One extra customer from Google more than covers it.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Primary Offer -->
      <div class="bg-white rounded-[2.5rem] shadow-xl border-2 border-orange-500 overflow-hidden relative transform lg:-translate-y-4">
        <div class="absolute top-0 inset-x-0 bg-orange-500 text-white text-center py-2 text-sm font-bold tracking-wider uppercase">
          Early Bird Offer — Limited Spots
        </div>
        <div class="p-10 pt-16">
          <h3 class="text-2xl font-bold text-slate-900 mb-2">Local Leader Package</h3>
          <p class="text-slate-500 mb-6">Everything you need to dominate local search.</p>
          
          <div class="mb-8">
            <div class="flex items-center gap-3 mb-1">
              <span class="text-2xl text-slate-400 line-through font-medium">$2,000</span>
              <span class="text-5xl font-extrabold text-slate-900">$500</span>
              <span class="text-slate-500">/month</span>
            </div>
            <p class="text-sm font-medium text-orange-600 bg-orange-50 inline-block px-3 py-1 rounded-full mt-2">Founding client pricing. Keep it forever.</p>
          </div>

          <a 
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            class="block w-full text-center bg-orange-600 text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-orange-700 transition-all shadow-lg shadow-orange-600/20 mb-8"
          >
            Claim This Price
          </a>

          <div class="space-y-4">
            <p class="font-bold text-slate-900">What's included:</p>
            <ul class="space-y-3 text-slate-600">
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Google Business Profile optimisation
              </li>
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                50+ local directory citations
              </li>
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Automated 5-star review engine
              </li>
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                SEO-optimised service pages
              </li>
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Monthly performance reporting
              </li>
            </ul>
          </div>
          
          <div class="mt-8 pt-8 border-t border-slate-100 text-sm text-slate-500 text-center">
            No ad spend required. 3-month initial commitment, then month-to-month.
          </div>
        </div>
      </div>

      <!-- Secondary Offer -->
      <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-200 overflow-hidden p-10 flex flex-col">
        <h3 class="text-2xl font-bold text-slate-900 mb-2">Brand & Authority</h3>
        <p class="text-slate-500 mb-6">For businesses that need a complete digital facelift.</p>
        
        <div class="mb-8">
          <span class="text-4xl font-extrabold text-slate-900">Custom</span>
          <p class="text-slate-500 mt-2">Tailored to your specific needs.</p>
        </div>

        <a 
          href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
          target="_blank"
          class="block w-full text-center bg-slate-100 text-slate-900 px-8 py-4 rounded-full font-bold text-lg hover:bg-slate-200 transition-all mb-8"
        >
          Discuss Your Needs
        </a>

        <div class="space-y-4 flex-grow">
          <p class="font-bold text-slate-900">Available services:</p>
          <ul class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Website design & refresh
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Logos and branding assets
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Social media post design
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Professional email setup
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
