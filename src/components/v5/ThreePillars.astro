---
---

<section id="how-it-works" class="py-24 bg-[#fbfaf7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-4xl font-extrabold text-slate-900 mb-6">
        The complete system to dominate your local market.
      </h2>
      <p class="text-xl text-slate-600">
        We don't just do "SEO". We build a machine that turns local searches into booked jobs, predictably and consistently.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      <!-- Pillar 1 -->
      <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl transition-shadow duration-300">
        <div class="w-14 h-14 bg-orange-100 text-orange-600 rounded-2xl flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Top of Google Maps</h3>
        <p class="text-slate-600 mb-6 leading-relaxed">
          Show up first when locals search for your service. If you're not in the top 3 on the map, you're invisible. We get you there and keep you there.
        </p>
        <ul class="space-y-3 text-sm text-slate-500">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Full Google Business Profile optimisation
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            50+ local directory listings
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Ongoing Maps ranking management
          </li>
        </ul>
      </div>

      <!-- Pillar 2 -->
      <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl transition-shadow duration-300">
        <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">First Page of Search</h3>
        <p class="text-slate-600 mb-6 leading-relaxed">
          Your business on Page 1 — not your competitors, not some directory. You. Organic traffic that comes to you every day without spending a cent on ads.
        </p>
        <ul class="space-y-3 text-sm text-slate-500">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            SEO-optimised service pages
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Technical website fixes
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Suburb expansion as rankings grow
          </li>
        </ul>
      </div>

      <!-- Pillar 3 -->
      <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl transition-shadow duration-300">
        <div class="w-14 h-14 bg-yellow-100 text-yellow-600 rounded-2xl flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">5-Star Review Engine</h3>
        <p class="text-slate-600 mb-6 leading-relaxed">
          Build a wall of 5-star reviews — without lifting a finger. More reviews means more trust means more calls. The obvious choice before anyone picks up the phone.
        </p>
        <ul class="space-y-3 text-sm text-slate-500">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Automated review requests
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Private feedback form for concerns
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Professional responses to all reviews
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-20 text-center">
      <a 
        href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
        target="_blank"
        class="inline-flex justify-center items-center bg-slate-900 text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-slate-800 transition-all"
      >
        Book a Free Strategy Session
      </a>
    </div>
  </div>
</section>
