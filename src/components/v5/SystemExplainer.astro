<section class="py-24 bg-white border-y border-slate-200">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <img 
          src="/images/v5-conversion-system.jpg" 
          alt="Visibility to Booked Jobs Conversion Path" 
          class="w-full h-auto rounded-3xl shadow-xl border border-slate-100"
        />
      </div>
      <div class="order-1 lg:order-2">
        <h2 class="text-4xl font-extrabold text-slate-900 mb-6">
          From invisible to the <span class="font-serif italic text-orange-600 font-medium">obvious choice.</span>
        </h2>
        <p class="text-xl text-slate-600 mb-8 leading-relaxed">
          We map the exact journey your customers take, from the moment they search for a service to the moment they call you.
        </p>
        
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-900 flex items-center justify-center font-bold flex-shrink-0">1</div>
            <div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Get Found</h4>
              <p class="text-slate-600">Rank at the top of Google Maps when high-intent customers search for your exact services.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-900 flex items-center justify-center font-bold flex-shrink-0">2</div>
            <div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Build Trust</h4>
              <p class="text-slate-600">Stand out with a wall of 5-star reviews that makes choosing anyone else feel like a risk.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-900 flex items-center justify-center font-bold flex-shrink-0">3</div>
            <div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Convert</h4>
              <p class="text-slate-600">Turn that traffic and trust into phone calls and booked jobs, predictably every month.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
