---
---

<section id="pricing" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-serif text-slate-900 mb-6">Simple, transparent pricing</h2>
      <p class="text-lg text-slate-600">
        What's your average job worth? One extra customer from Google more than covers your monthly investment.
      </p>
    </div>

    <div class="max-w-lg mx-auto">
      <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden relative">
        <div class="absolute top-0 inset-x-0 h-2 bg-blue-600"></div>
        <div class="p-8 sm:p-10">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-2xl font-bold text-slate-900">Local Dominance</h3>
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-bold uppercase tracking-wider">
              Early Bird
            </span>
          </div>
          
          <div class="flex items-baseline gap-2 mb-2">
            <span class="text-5xl font-black text-slate-900">$500</span>
            <span class="text-lg text-slate-500 font-medium">/month</span>
          </div>
          <p class="text-sm text-slate-500 line-through mb-8">Normally $2,000/month</p>
          
          <p class="text-slate-600 mb-8 pb-8 border-b border-slate-100">
            Everything you need to dominate your local area. No ad spend required. No lock-in after initial 3-month commitment. Month-to-month after that.
          </p>
          
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-700">Top 3 Google Maps Ranking</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-700">First Page Organic Search SEO</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-700">Automated 5-Star Review System</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-700">Google Business Profile Management</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-slate-700">Monthly Performance Reporting</span>
            </li>
          </ul>
          
          <a
            href="#book-call"
            class="block w-full py-4 px-6 text-center text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-xl transition-colors duration-200"
          >
            Claim Early Bird Pricing
          </a>
        </div>
      </div>
      
      <div class="mt-8 text-center">
        <p class="text-sm text-slate-500">
          For businesses ready to take the next step: <a href="#book-call" class="text-blue-600 hover:underline font-medium">Book a call for custom pricing.</a>
        </p>
      </div>
    </div>
  </div>
</section>
