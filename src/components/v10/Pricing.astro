---
const localLeaderIncludes = [
  "Top 3 Google Maps ranking",
  "First page organic search SEO",
  "Automated 5-star review system",
  "Google Business Profile management",
  "Monthly performance reporting",
];

const brandingIncludes = [
  "Website design and refresh support",
  "Logos and brand assets",
  "Social media post design",
  "Graphic design collateral",
  "Email signature setup",
  "Professional business email setup",
];
---

<section id="pricing" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-serif text-slate-900 mb-6">Simple, transparent pricing</h2>
      <p class="text-lg text-slate-600">
        What's your average job worth? One extra customer from Google more than covers your monthly investment.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
      <div class="relative overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/92 p-8 shadow-[0_26px_70px_rgba(15,23,42,0.10)] sm:p-10">
        <div class="absolute inset-x-0 top-0 h-2 bg-blue-600"></div>
        <div class="absolute right-0 top-0 h-48 w-48 rounded-full bg-blue-100/70 blur-3xl"></div>

        <div class="relative flex flex-wrap items-start justify-between gap-5">
          <div>
            <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-xs font-bold uppercase tracking-[0.22em] text-blue-700">
              Early Bird Offer
            </span>
            <h3 class="mt-5 text-3xl font-bold text-slate-900">Local Leader Package</h3>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-slate-600">
              Everything you need to become the obvious choice in your local area on Google.
            </p>
          </div>
          <div class="rounded-[1.35rem] border border-slate-200/80 bg-white/90 px-4 py-3 text-right shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Founding rate</p>
            <p class="mt-2 text-sm font-medium text-slate-700">Keep this rate while you stay on</p>
          </div>
        </div>

        <div class="relative mt-8 flex items-baseline gap-2">
          <span class="text-5xl font-black text-slate-900">$500</span>
          <span class="text-lg font-medium text-slate-500">/month</span>
        </div>
        <p class="mt-2 text-sm text-slate-500"><span class="line-through">Normally $2,000/month</span> · No lock-in after initial 3-month commitment</p>

        <ul class="mt-8 space-y-4 border-t border-slate-100 pt-8">
          {
            localLeaderIncludes.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 shrink-0 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-slate-700">{item}</span>
              </li>
            ))
          }
        </ul>

        <a
          href="#book-call"
          class="mt-10 block w-full rounded-xl bg-blue-600 px-6 py-4 text-center font-semibold text-white transition-colors duration-200 hover:bg-blue-700"
        >
          Claim Early Bird Pricing
        </a>
      </div>

      <div class="relative rounded-[2rem] border border-slate-200/80 bg-[#fcfbf7]/92 p-8 shadow-[0_20px_55px_rgba(15,23,42,0.08)] sm:p-10">
        <div class="flex flex-wrap items-start justify-between gap-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Custom Scope</p>
            <h3 class="mt-4 text-2xl font-bold text-slate-900">Brand & Authority Package</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              For service businesses that also want their website and brand presence to look as strong as their rankings.
            </p>
          </div>
          <div class="rounded-[1.35rem] bg-white px-4 py-3 text-right shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Pricing</p>
            <p class="mt-2 text-sm font-semibold text-slate-900">Custom pricing</p>
          </div>
        </div>

        <ul class="mt-8 space-y-4">
          {
            brandingIncludes.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-slate-700">{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 rounded-[1.5rem] bg-white px-5 py-4 text-sm leading-relaxed text-slate-600 shadow-sm">
          A broader brand support package for operators who want Local Leader handling both lead generation and brand presentation.
        </div>

        <a
          href="#book-call"
          class="mt-8 block w-full rounded-xl border border-slate-200 bg-white px-6 py-4 text-center font-medium text-slate-900 transition-colors duration-200 hover:bg-slate-50"
        >
          Ask About Custom Pricing
        </a>
      </div>
    </div>
  </div>
</section>
