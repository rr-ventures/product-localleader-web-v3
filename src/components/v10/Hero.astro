---
---

<section class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-28">
  <div class="absolute inset-x-0 top-0 h-[34rem] bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.95),transparent_34%),radial-gradient(circle_at_18%_18%,rgba(226,232,240,0.7),transparent_26%)] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] gap-14 lg:gap-10 items-center">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-sm font-medium mb-8 border border-blue-100">
          <span class="flex h-2 w-2 rounded-full bg-blue-600"></span>
          For Australian Service Providers
        </div>

        <h1 class="text-5xl lg:text-6xl font-serif text-slate-900 leading-[1.05] mb-6 tracking-tight">
          Become the <span class="text-blue-600 italic">#1 service provider</span> in your area.
        </h1>

        <p class="text-lg text-slate-600 mb-10 leading-relaxed max-w-xl">
          We get you to the top of Google Maps, first page of Google, and build your 5-star reputation — no ad spend required. Stop chasing work and start choosing it.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#book-call"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-full text-white bg-slate-900 hover:bg-slate-800 shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
          >
            Book a Free Strategy Session
          </a>
          <a
            href="/v10/thank-you"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-full text-slate-700 bg-white border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all duration-200"
          >
            Request a Local Ranking Audit
          </a>
        </div>
      </div>

      <div class="relative mx-auto min-h-[31rem] w-full max-w-[32rem] lg:ml-auto sm:min-h-[35rem]">
        <div class="absolute -left-4 top-10 h-40 w-40 rounded-full bg-sky-200/40 blur-[90px]"></div>
        <div class="absolute -right-6 top-20 h-44 w-44 rounded-full bg-white/80 blur-[95px]"></div>
        <div class="absolute right-10 bottom-10 h-36 w-36 rounded-full bg-blue-100/50 blur-[90px]"></div>
        <div class="absolute inset-x-[18%] bottom-2 h-12 rounded-full bg-slate-950/12 blur-3xl"></div>

        <div class="absolute left-0 top-5 w-[15.75rem] rounded-[1.9rem] border border-white/75 bg-white/88 p-5 shadow-[0_28px_70px_rgba(15,23,42,0.14)] backdrop-blur-[6px] sm:w-[17rem] sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-50 shadow-inner shadow-sky-100">
              <img src="/images/localleader-map-pin-mark.png" alt="" class="h-7 w-auto opacity-95" />
            </div>
            <div class="rounded-full border border-emerald-200/80 bg-emerald-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-emerald-700">
              +25% Visibility
            </div>
          </div>
          <p class="mt-6 text-[1.95rem] font-semibold leading-[1.02] tracking-tight text-slate-900 sm:text-[2.15rem]">
            Become a top result in Google Maps
          </p>
          <div class="mt-5 flex items-end justify-between gap-4">
            <p class="text-sm text-slate-500">Map pack signal lift</p>
            <div class="flex items-end gap-1">
              <span class="h-3 w-8 rounded-full bg-sky-200"></span>
              <span class="h-4 w-10 rounded-full bg-sky-300"></span>
              <span class="h-5 w-12 rounded-full bg-blue-500"></span>
            </div>
          </div>
        </div>

        <div class="absolute right-0 top-[10.75rem] w-[14.75rem] rounded-[1.9rem] border border-white/80 bg-white/92 p-5 shadow-[0_34px_75px_rgba(15,23,42,0.16)] backdrop-blur-[8px] sm:top-[12.25rem] sm:w-[16rem] sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <div class="flex gap-1 text-amber-400">
              {Array.from({ length: 5 }).map(() => (
                <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                </svg>
              ))}
            </div>
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Trust</span>
          </div>
          <div class="mt-5 flex items-end gap-2">
            <p class="text-5xl font-semibold tracking-tight text-slate-900">4.9</p>
            <p class="pb-1 text-lg font-medium text-slate-600">Rating</p>
          </div>
          <p class="mt-1 text-base text-slate-500">(215 Google reviews)</p>
          <div class="mt-5 flex items-center justify-between gap-3 rounded-2xl bg-slate-50 px-4 py-3">
            <div class="flex -space-x-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-slate-200 text-[11px] font-semibold text-slate-700">JM</span>
              <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-slate-200 text-[11px] font-semibold text-slate-700">SW</span>
              <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-slate-200 text-[11px] font-semibold text-slate-700">RK</span>
            </div>
            <p class="text-sm font-medium text-slate-600">Customer trust score</p>
          </div>
        </div>

        <div class="absolute left-4 bottom-0 w-[16.5rem] rounded-[1.95rem] border border-white/75 bg-white/88 p-5 shadow-[0_30px_78px_rgba(15,23,42,0.14)] backdrop-blur-[6px] sm:left-8 sm:w-[18rem] sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <div class="text-4xl font-semibold tracking-tight text-slate-300">G</div>
            <div class="rounded-full border border-blue-200/80 bg-blue-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-blue-700">
              +28 Ranking Gains
            </div>
          </div>
          <p class="mt-4 text-[1.85rem] font-semibold leading-[1.04] tracking-tight text-slate-900 sm:text-[2rem]">
            Get on the 1st page of Google
          </p>
          <div class="mt-5 flex items-end justify-between gap-4">
            <p class="text-sm text-slate-500">Organic search momentum</p>
            <div class="flex items-center gap-1">
              <span class="h-2 w-6 rounded-full bg-slate-200"></span>
              <span class="h-2.5 w-7 rounded-full bg-slate-300"></span>
              <span class="h-3 w-8 rounded-full bg-blue-500"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
