---
import BrandLogo from "../shared/BrandLogo.astro";
---

<footer class="bg-transparent border-t border-gray-200 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        <BrandLogo href="/v10" size="md" className="mb-6" imageClassName="drop-shadow-none group-hover:drop-shadow-none group-hover:translate-y-0" />
        <p class="text-gray-500 text-sm leading-relaxed max-w-sm">
          Helping Australian service providers dominate their local area through Google Maps, organic search, and automated 5-star reviews.
        </p>
      </div>
      <div>
        <h4 class="font-semibold text-gray-900 mb-4">Services</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Google Maps SEO</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Organic Search</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Review Automation</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-gray-900 mb-4">Company</h4>
        <ul class="space-y-3">
          <li><a href="/v10/thank-you" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Free Ranking Audit</a></li>
          <li><a href="#book-call" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Book a Call</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-400">
        &copy; {new Date().getFullYear()} Local Leader. All rights reserved.
      </p>
      <div class="flex space-x-6">
        <a href="#" class="text-sm text-gray-400 hover:text-gray-900 transition-colors">Privacy Policy</a>
        <a href="#" class="text-sm text-gray-400 hover:text-gray-900 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
