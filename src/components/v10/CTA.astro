---
const bookingUrl =
  "https://calendar.google.com/calendar/appointments/schedules/AcZssZ0AghtsBW18FSrSjYsH1Y1yRHZYE0eTc_CeQkgGDs4PkqcP7PJy0m8X-iPuB8Z0BZfeSq93o3B0?gv=true";
---

<section id="book-call" class="relative overflow-hidden bg-slate-900 py-24 text-white">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/35 via-slate-900 to-slate-900"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-4xl font-serif md:text-5xl">Book your free strategy call</h2>
      <p class="mx-auto mb-12 max-w-2xl text-xl text-slate-300">
        Pick a time on the page below and lock in your strategy session without leaving the site.
      </p>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white p-3 shadow-[0_28px_90px_rgba(15,23,42,0.45)]">
      <iframe
        src={bookingUrl}
        title="Book a free strategy call"
        class="min-h-[720px] w-full rounded-[1.4rem] bg-white"
        style="border:0;"
        width="100%"
        height="720"
        frameborder="0"
      ></iframe>
    </div>

    <div class="mt-6 text-center">
      <p class="text-sm text-slate-400">
        If the booking widget has trouble loading, <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="font-medium text-white underline underline-offset-4">open the scheduler directly</a>.
      </p>
    </div>
  </div>
</section>
