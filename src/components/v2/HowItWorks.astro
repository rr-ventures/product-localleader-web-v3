---
---

<section class="mt-32 relative z-10 pb-20">
  <div class="text-center mb-16 flex flex-col items-center">
    <span class="px-4 py-1.5 bg-white rounded-full text-sm font-medium shadow-sm border border-gray-100 mb-6 inline-block">
      The Three Pillars
    </span>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 max-w-2xl">
      How we make you the <span class="font-serif italic font-normal">obvious</span> choice.
    </h2>
  </div>

  <div class="grid md:grid-cols-3 gap-8">
    <!-- Card 1 -->
    <div class="bg-white rounded-[2rem] p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-50 flex flex-col h-full">
      <div class="bg-[#F8F9FA] rounded-2xl p-6 mb-8 h-48 flex items-center justify-center relative overflow-hidden group">
        <!-- Abstract Map Visual -->
        <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-indigo-50/50"></div>
        <div class="relative z-10 w-full max-w-[180px] space-y-3">
          <div class="bg-white p-3 rounded-xl shadow-sm border border-gray-100 flex items-center gap-3 transform transition-transform group-hover:-translate-y-1">
            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="flex-1">
              <div class="h-2 w-16 bg-gray-200 rounded-full mb-1.5"></div>
              <div class="h-1.5 w-10 bg-gray-100 rounded-full"></div>
            </div>
          </div>
          <div class="bg-white/60 p-3 rounded-xl shadow-sm border border-gray-100/50 flex items-center gap-3 blur-[1px]">
            <div class="w-8 h-8 rounded-full bg-gray-200"></div>
            <div class="flex-1">
              <div class="h-2 w-16 bg-gray-200 rounded-full mb-1.5"></div>
              <div class="h-1.5 w-10 bg-gray-100 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      <h3 class="text-2xl font-bold mb-3 text-gray-900">Top of Google Maps</h3>
      <p class="text-gray-500 leading-relaxed">
        When someone searches "[your trade] near me", we get you in the top 3 spots. Your phone rings from people ready to hire, not tyre-kickers.
      </p>
    </div>

    <!-- Card 2 -->
    <div class="bg-white rounded-[2rem] p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-50 flex flex-col h-full">
      <div class="bg-[#F8F9FA] rounded-2xl p-6 mb-8 h-48 flex items-center justify-center relative overflow-hidden group">
        <!-- Abstract Search Visual -->
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50 to-pink-50/50"></div>
        <div class="relative z-10 w-full max-w-[200px]">
          <div class="bg-white rounded-full px-4 py-2.5 shadow-sm border border-gray-100 flex items-center gap-2 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <div class="h-1.5 w-24 bg-gray-200 rounded-full"></div>
          </div>
          <div class="space-y-3 pl-2">
            <div class="space-y-1.5 transform transition-transform group-hover:translate-x-1">
              <div class="h-2 w-32 bg-purple-200 rounded-full"></div>
              <div class="h-1.5 w-full bg-gray-100 rounded-full"></div>
              <div class="h-1.5 w-4/5 bg-gray-100 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      <h3 class="text-2xl font-bold mb-3 text-gray-900">First Page of Google</h3>
      <p class="text-gray-500 leading-relaxed">
        Show up first when locals search for your trade. Organic traffic that comes to you every day without spending a cent on ads.
      </p>
    </div>

    <!-- Card 3 -->
    <div class="bg-white rounded-[2rem] p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-50 flex flex-col h-full">
      <div class="bg-[#F8F9FA] rounded-2xl p-6 mb-8 h-48 flex items-center justify-center relative overflow-hidden group">
        <!-- Abstract Review Visual -->
        <div class="absolute inset-0 bg-gradient-to-br from-amber-50 to-orange-50/50"></div>
        <div class="relative z-10 flex flex-col items-center justify-center transform transition-transform group-hover:scale-105">
          <div class="text-4xl font-bold text-gray-900 mb-2">5.0</div>
          <div class="flex gap-1 mb-2">
            {[1, 2, 3, 4, 5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#F59E0B" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <div class="h-1.5 w-16 bg-gray-200 rounded-full mt-2"></div>
        </div>
      </div>
      <h3 class="text-2xl font-bold mb-3 text-gray-900">5-Star Review Engine</h3>
      <p class="text-gray-500 leading-relaxed">
        A system that generates real Google reviews from happy customers automatically. More reviews means more trust and more calls.
      </p>
    </div>
  </div>

  <div class="mt-16 text-center">
    <a 
      href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5" 
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-8 py-4 bg-black text-white rounded-full font-medium hover:bg-gray-800 hover:scale-105 transition-all shadow-lg"
    >
      Book Your Free Strategy Call
    </a>
  </div>
</section>
