---
const localLeaderIncludes = [
  "Top 3 Google Maps ranking",
  "First page organic search SEO",
  "Automated 5-star review system",
  "Google Business Profile management",
  "Monthly performance reporting",
];

const brandingIncludes = [
  "Website design and refresh support",
  "Logos and brand assets",
  "Social media post design",
  "Graphic design collateral",
  "Email signature setup",
  "Professional business email setup",
];
---

<section id="pricing" class="relative z-10 mt-32 pb-20">
  <div class="mb-16 text-center">
    <span class="mb-6 inline-block rounded-full border border-white/70 bg-white/90 px-4 py-1.5 text-sm font-medium shadow-sm">
      Pricing
    </span>
    <h2 class="mx-auto max-w-3xl text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">
      Simple pricing for the <span class="font-serif font-normal italic">main growth offer</span>, with a second authority package when you need it.
    </h2>
  </div>

  <div class="grid gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
    <div class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-black p-8 text-white shadow-[0_32px_90px_rgba(15,23,42,0.22)] sm:p-10">
      <div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-sky-500/20 blur-3xl"></div>
      <div class="absolute left-0 top-0 h-1.5 w-full bg-gradient-to-r from-teal-400 via-sky-400 to-blue-500"></div>

      <div class="relative flex flex-wrap items-start justify-between gap-5">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/8 px-4 py-2 text-xs font-bold uppercase tracking-[0.22em] text-teal-200">
            <span class="h-2 w-2 rounded-full bg-teal-300"></span>
            Early Bird Offer
          </span>
          <h3 class="mt-5 text-3xl font-semibold text-white">Local Leader Package</h3>
          <p class="mt-3 max-w-md text-sm leading-relaxed text-gray-300">
            Everything you need to become the obvious choice in your local area on Google.
          </p>
        </div>
        <div class="rounded-[1.35rem] border border-white/10 bg-white/6 px-4 py-3 text-right">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">Founding rate</p>
          <p class="mt-2 text-sm font-medium text-gray-200">Keep this rate while you stay on</p>
        </div>
      </div>

      <div class="relative mt-8 flex items-end gap-2">
        <span class="text-6xl font-semibold tracking-tight text-white">$500</span>
        <span class="mb-2 text-lg font-medium text-gray-400">/month</span>
      </div>
      <p class="mt-2 text-sm text-gray-500"><span class="line-through">$2,000/month</span> · No lock-in after initial 3-month commitment</p>

      <ul class="relative mt-8 space-y-4 border-t border-white/10 pt-8">
        {
          localLeaderIncludes.map((item) => (
            <li class="flex items-start gap-3 text-sm text-gray-300">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-teal-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>

      <a
        href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
        target="_blank"
        rel="noopener noreferrer"
        class="relative mt-10 block w-full rounded-full bg-white px-6 py-4 text-center font-semibold text-black transition-all hover:-translate-y-0.5 hover:bg-gray-100"
      >
        Claim Early Bird Pricing
      </a>
    </div>

    <div class="rounded-[2.25rem] border border-gray-200/80 bg-white/92 p-8 shadow-[0_24px_65px_rgba(15,23,42,0.08)] backdrop-blur sm:p-10">
      <div class="flex flex-wrap items-start justify-between gap-5">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-400">Custom Scope</p>
          <h3 class="mt-4 text-2xl font-semibold text-gray-900">Brand & Authority Package</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-600">
            For trade businesses that want Local Leader to help polish the brand layer as well as the lead flow.
          </p>
        </div>
        <div class="rounded-[1.35rem] bg-[#F8F9FA] px-4 py-3 text-right">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">Pricing</p>
          <p class="mt-2 text-sm font-semibold text-gray-900">Custom pricing</p>
        </div>
      </div>

      <ul class="mt-8 space-y-4">
        {
          brandingIncludes.map((item) => (
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-gray-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>

      <div class="mt-8 rounded-[1.5rem] bg-[#F8F9FA] px-5 py-4 text-sm leading-relaxed text-gray-600">
        Ideal for businesses that want stronger presentation across their website, branded assets, and customer-facing touchpoints.
      </div>

      <a
        href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-gray-200 px-6 py-4 text-center font-medium text-gray-900 transition-all hover:-translate-y-0.5 hover:border-gray-300 hover:bg-gray-50"
      >
        Ask About Custom Pricing
      </a>
    </div>
  </div>
</section>
