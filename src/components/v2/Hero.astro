---
---

<section class="relative z-10 mt-16 grid items-center gap-14 lg:mt-24 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.05fr)]">
  <div class="max-w-2xl">
    <div class="mb-8 flex flex-wrap gap-3">
      <span class="rounded-full border border-white/70 bg-white/90 px-4 py-1.5 text-sm font-medium shadow-sm">Top of Maps</span>
      <span class="rounded-full border border-white/70 bg-white/90 px-4 py-1.5 text-sm font-medium shadow-sm">First Page Google</span>
      <span class="rounded-full border border-white/70 bg-white/90 px-4 py-1.5 text-sm font-medium shadow-sm">5-Star Reviews</span>
    </div>

    <h1 class="mb-6 text-5xl font-bold leading-[1.02] tracking-tight text-gray-900 sm:text-6xl lg:text-7xl">
      Become the <span class="font-serif italic font-normal">#1 tradie</span><br />
      in your area.
    </h1>

    <p class="mb-10 max-w-xl text-lg leading-relaxed text-gray-600">
      Stop chasing work. Start choosing it. We help Australian trade businesses dominate their local area with Google Maps visibility, page-one rankings, and review proof that makes you the obvious choice.
    </p>

    <div class="flex flex-wrap items-center gap-4">
      <a
        href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-black px-8 py-4 font-medium text-white shadow-[0_20px_40px_rgba(17,24,39,0.18)] transition-all hover:scale-105 hover:bg-gray-800"
      >
        Book Your Free Strategy Call
      </a>

      <a
        href="/v2/thank-you"
        class="group flex items-center gap-3 rounded-full border border-gray-200/80 bg-white/90 px-2 py-1 pr-6 shadow-sm transition-all hover:scale-105 hover:shadow-md"
      >
        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-gradient-to-br from-teal-500 to-sky-500 text-sm font-semibold text-white shadow-inner">
          LL
        </div>
        <div class="flex flex-col">
          <span class="text-sm font-medium leading-tight transition-colors group-hover:text-black">Get Your Free Audit</span>
          <span class="flex items-center gap-1 text-xs text-emerald-600">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Available now
          </span>
        </div>
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-6 text-sm text-gray-500">
      <div>
        <p class="text-2xl font-semibold text-gray-900">150+</p>
        <p>Review signals built into the offer</p>
      </div>
      <div>
        <p class="text-2xl font-semibold text-gray-900">Top 3</p>
        <p>Google Maps is the target outcome</p>
      </div>
      <div>
        <p class="text-2xl font-semibold text-gray-900">$999/mo</p>
        <p>No lock-in contracts</p>
      </div>
    </div>
  </div>

  <div class="relative mx-auto w-full max-w-[44rem]">
    <div class="absolute -left-10 top-12 h-40 w-40 rounded-full bg-teal-200/45 blur-3xl"></div>
    <div class="absolute -right-10 bottom-0 h-52 w-52 rounded-full bg-sky-200/45 blur-3xl"></div>
    <div class="absolute inset-x-12 top-4 h-24 rounded-full bg-gradient-to-r from-transparent via-cyan-200/40 to-transparent blur-3xl"></div>

    <div class="absolute left-0 top-10 hidden rounded-[1.75rem] border border-white/70 bg-white/85 p-4 shadow-[0_22px_55px_rgba(15,23,42,0.12)] backdrop-blur md:block">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-gray-400">Visibility lift</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900">+28</p>
      <p class="text-sm text-gray-500">ranking improvements</p>
    </div>

    <div class="absolute right-0 top-0 hidden rounded-[1.75rem] border border-white/70 bg-white/90 p-5 shadow-[0_24px_60px_rgba(17,24,39,0.14)] backdrop-blur md:block">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-gray-400">Review proof</p>
      <div class="mt-3 flex items-center gap-3">
        <p class="text-3xl font-semibold text-gray-900">4.9</p>
        <div class="flex gap-1 text-amber-400">
          {[1, 2, 3, 4, 5].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="m12 17.27 6.18 3.73-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"></path>
            </svg>
          ))}
        </div>
      </div>
    </div>

    <div class="absolute inset-x-[16%] bottom-4 h-12 rounded-full bg-slate-900/12 blur-3xl"></div>
    <img
      src="/images/hero-v2.jpg"
      alt="Before and after Google Maps ranking proof for a local trade business"
      class="relative h-auto w-full object-contain drop-shadow-[0_36px_80px_rgba(15,23,42,0.18)]"
    />

    <div class="absolute bottom-6 left-10 hidden rounded-[1.5rem] border border-white/70 bg-slate-950 px-5 py-4 text-white shadow-[0_20px_55px_rgba(15,23,42,0.3)] md:block">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/50">Core result</p>
      <p class="mt-2 text-lg font-medium">Look established before the first phone call.</p>
    </div>
  </div>
</section>
