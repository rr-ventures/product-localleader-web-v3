---
---

<section id="book-call" class="py-16 bg-funnel-light md:py-20 scroll-mt-8">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="mb-4 text-center">
      <h2 class="text-3xl font-extrabold text-funnel-text md:text-4xl">
        Book Your Free 15-Minute Strategy Call
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-500 max-w-xl mx-auto">
        No pressure. No pitch. Just a straight conversation about your market and whether we can help you become the #1 agent in your area.
      </p>
    </div>

    <!-- Calendly embed placeholder -->
    <div
      id="calendly-embed"
      class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
      style="min-height: 600px;"
    >
      <!--
        PASTE CALENDLY EMBED CODE HERE
        Configure:
          - 15-minute intro call
          - 4-day max lookahead
          - Email + SMS reminders at 24hrs and 1hr
        Example inline embed:
        <div class="calendly-inline-widget" data-url="https://calendly.com/reece-localleader/15min" style="min-width:320px;height:700px;"></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      -->
      <div class="flex h-full min-h-[600px] flex-col items-center justify-center gap-4 p-8 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-funnel-primary/10">
          <svg class="h-8 w-8 text-funnel-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <p class="text-lg font-bold text-funnel-text">Calendly Booking Widget</p>
          <p class="mt-1 text-sm text-slate-400">Paste your Calendly embed code above to activate the booking widget.</p>
        </div>
      </div>
    </div>

    <!-- Scarcity note -->
    <div class="mt-6 flex items-start gap-3 rounded-xl border border-amber-200 bg-amber-50 px-5 py-4">
      <span class="text-xl flex-shrink-0" aria-hidden="true">🔒</span>
      <p class="text-sm text-amber-800 leading-snug">
        <strong>Spots are limited.</strong> We only take on a handful of clients at a time so we can give every agent the focused attention it takes to get them ranking at the top of their suburb.
      </p>
    </div>
  </div>
</section>
