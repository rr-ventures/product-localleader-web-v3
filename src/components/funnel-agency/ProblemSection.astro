---
import FunnelCta from "../funnel/FunnelCta.astro";

const painPoints = [
  "You're paying thousands to portals and comparison sites but getting price-sensitive leads",
  "You've been burned by agencies before — paid for impressions and clicks, got zero appraisals",
  "The franchise down the street is showing up on Google and you're nowhere to be found",
  "You're stuck on OpenAgent and RateMyAgent racing to the bottom on commission",
  "Your pipeline only flows when you're prospecting 4+ hours a day — never on autopilot",
];
---

<section class="py-16 bg-white md:py-20">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold text-funnel-text md:text-4xl">
      Sound Familiar?
    </h2>

    <ul class="mt-8 space-y-4">
      {painPoints.map((point) => (
        <li class="flex items-start gap-4 rounded-xl border border-slate-200 bg-funnel-light px-5 py-4">
          <!-- Unchecked checkbox icon -->
          <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded border-2 border-slate-400 bg-white" aria-hidden="true"></span>
          <span class="text-base text-slate-700 leading-snug">{point}</span>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-xl font-bold text-funnel-text md:text-2xl">
      You don't have a skills problem. You have a visibility problem.
    </p>

    <div class="mt-8">
      <FunnelCta text="Let's Fix That — Book a Call →" />
    </div>
  </div>
</section>
