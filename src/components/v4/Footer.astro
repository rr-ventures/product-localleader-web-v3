---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <img src="/images/v4-logo.jpg" alt="Local Leader" class="h-8 w-auto mix-blend-multiply grayscale opacity-80" />
      </div>
      
      <nav class="flex gap-6 text-sm text-gray-500">
        <a href="/v4" class="hover:text-gray-900 transition-colors">Home</a>
        <a href="#how-it-works" class="hover:text-gray-900 transition-colors">How it Works</a>
        <a href="#pricing" class="hover:text-gray-900 transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-gray-900 transition-colors">FAQ</a>
      </nav>
      
      <div class="text-sm text-gray-400">
        &copy; {currentYear} Local Leader. All rights reserved.
      </div>
    </div>
  </div>
</footer>
