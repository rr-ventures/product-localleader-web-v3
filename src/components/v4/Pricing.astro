---
---

<section id="pricing" class="py-24 bg-white border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6 font-serif tracking-tight">
        Simple, transparent pricing.
      </h2>
      <p class="text-lg text-gray-600 font-sans">
        What's your average job worth? One extra customer from Google more than covers it.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
      
      <!-- Tier 1: Local Leader Package -->
      <div class="relative bg-[#fcfbf8] rounded-3xl border-2 border-gray-900 p-8 md:p-10 shadow-xl flex flex-col">
        <div class="absolute top-0 right-8 transform -translate-y-1/2">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700 border border-red-200 shadow-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd" /></svg>
            EARLY BIRD OFFER
          </span>
        </div>
        
        <div class="mb-8">
          <h3 class="text-2xl font-bold text-gray-900 font-serif mb-2">Local Leader Package</h3>
          <p class="text-gray-600">Everything you need to dominate local search.</p>
        </div>
        
        <div class="mb-8 flex items-baseline gap-3">
          <span class="text-gray-400 line-through text-2xl font-medium">$2,000</span>
          <span class="text-5xl font-bold text-gray-900 font-serif">$500</span>
          <span class="text-gray-500 font-medium">/month</span>
        </div>
        
        <p class="text-sm font-medium text-gray-900 mb-6 bg-gray-100 p-3 rounded-lg border border-gray-200">
          Limited spots. Founding client pricing. You keep that rate as long as you stay.
        </p>

        <ul class="space-y-4 mb-10 flex-1">
          <li class="flex gap-3 text-gray-700">
            <svg class="w-6 h-6 text-gray-900 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Top of Google Maps ranking</span>
          </li>
          <li class="flex gap-3 text-gray-700">
            <svg class="w-6 h-6 text-gray-900 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>First Page of Google Search</span>
          </li>
          <li class="flex gap-3 text-gray-700">
            <svg class="w-6 h-6 text-gray-900 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>5-Star Review Engine</span>
          </li>
          <li class="flex gap-3 text-gray-700">
            <svg class="w-6 h-6 text-gray-900 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>No ad spend required</span>
          </li>
          <li class="flex gap-3 text-gray-700">
            <svg class="w-6 h-6 text-gray-900 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Month-to-month after initial 3-months</span>
          </li>
        </ul>

        <a 
          href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5" 
          target="_blank"
          rel="noopener noreferrer"
          class="w-full inline-flex h-14 items-center justify-center rounded-xl bg-gray-900 px-8 text-base font-medium text-white shadow-md hover:bg-gray-800 transition-all"
        >
          Claim Early Bird Pricing
        </a>
      </div>

      <!-- Tier 2: Brand & Authority Package -->
      <div class="bg-white rounded-3xl border border-gray-200 p-8 md:p-10 flex flex-col">
        <div class="mb-8">
          <h3 class="text-2xl font-bold text-gray-900 font-serif mb-2">Brand & Authority Package</h3>
          <p class="text-gray-600">For businesses that need a complete digital overhaul.</p>
        </div>
        
        <div class="mb-8 flex items-baseline gap-2">
          <span class="text-4xl font-bold text-gray-900 font-serif">Custom</span>
        </div>
        
        <p class="text-sm text-gray-500 mb-6">
          Everything in the Local Leader Package, plus a complete brand refresh.
        </p>

        <ul class="space-y-4 mb-10 flex-1">
          <li class="flex gap-3 text-gray-600">
            <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Website design & refresh</span>
          </li>
          <li class="flex gap-3 text-gray-600">
            <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Logos and branding assets</span>
          </li>
          <li class="flex gap-3 text-gray-600">
            <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Social media post design</span>
          </li>
          <li class="flex gap-3 text-gray-600">
            <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Professional business email setup</span>
          </li>
        </ul>

        <a 
          href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5" 
          target="_blank"
          rel="noopener noreferrer"
          class="w-full inline-flex h-14 items-center justify-center rounded-xl bg-white border-2 border-gray-200 px-8 text-base font-medium text-gray-900 hover:bg-gray-50 hover:border-gray-300 transition-all"
        >
          Discuss Custom Scope
        </a>
      </div>

    </div>
  </div>
</section>
