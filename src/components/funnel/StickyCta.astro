<!-- Sticky CTA bar — visible on mobile only, fixed to bottom of viewport -->
<div class="fixed bottom-0 left-0 right-0 z-50 lg:hidden">
  <div class="border-t border-slate-200 bg-white/95 px-4 py-3 shadow-[0_-4px_24px_rgba(0,0,0,0.10)] backdrop-blur-sm">
    <a
      href="#book-call"
      class="flex w-full items-center justify-center gap-2 rounded-xl bg-funnel-accent py-4 text-base font-bold text-white shadow-md transition-all duration-200 active:scale-95"
      aria-label="Book a free strategy call"
    >
      <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Book Your Free Strategy Call
    </a>
  </div>
</div>

<!-- Spacer so sticky bar doesn't overlap page content on mobile -->
<div class="h-20 lg:hidden" aria-hidden="true"></div>
