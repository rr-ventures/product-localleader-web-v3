---
import FunnelCta from "./FunnelCta.astro";

const steps = [
  {
    number: "1",
    title: "Book Your Free Strategy Call",
    body: "We'll have a straight conversation about your business, your area, and whether we can help. No pressure, no pitch — just clarity.",
  },
  {
    number: "2",
    title: "We Build Your Local Dominance Plan",
    body: "If it's a fit, we'll map out exactly how to get you to #1 in your area — your Google Maps ranking, your website, your reviews. Everything tailored to your trade and location.",
  },
  {
    number: "3",
    title: "Watch Your Phone Start Ringing",
    body: "We handle everything. You stay on the tools. Within weeks, you'll see your rankings climb, your reviews grow, and your phone ring with the right kind of work.",
  },
];
---

<section class="py-16 bg-funnel-primary md:py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">
        Here's What Happens Next
      </h2>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      {steps.map((step) => (
        <div class="relative flex flex-col items-start">
          <!-- Large step number -->
          <div class="mb-4 flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-funnel-accent text-3xl font-extrabold text-white shadow-lg">
            {step.number}
          </div>
          <h3 class="mb-3 text-lg font-bold text-white">{step.title}</h3>
          <p class="text-sm leading-relaxed text-blue-100">{step.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <FunnelCta text="Start With Step 1 — Book a Call →" variant="light" />
    </div>
  </div>
</section>
