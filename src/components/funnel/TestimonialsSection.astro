---
import FunnelCta from "./FunnelCta.astro";

// PLACEHOLDER TESTIMONIALS — replace with real client testimonials before launch
const testimonials = [
  {
    quote: "Within 8 weeks my phone was ringing with jobs I didn't have to quote against three other blokes for.",
    name: "Dave M.",
    trade: "Electrician",
    location: "Newcastle NSW",
  },
  {
    quote: "I'd been burned by two agencies before. These guys just showed me the data, told me what they'd do, and did it. No BS.",
    name: "Sarah T.",
    trade: "Plumber",
    location: "Gold Coast QLD",
  },
  {
    quote: "We went from 14 Google reviews to 52 in four months. My phone rings before 8am most mornings now.",
    name: "Chris W.",
    trade: "Landscaper",
    location: "Melbourne VIC",
  },
];
---

<section class="py-16 bg-white md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-extrabold text-funnel-text md:text-4xl">
        What Our Clients Are Saying
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="flex flex-col rounded-2xl border border-slate-200 bg-funnel-light p-7 shadow-sm">
          <!-- Stars -->
          <div class="mb-4 flex text-funnel-accent text-xl" aria-label="5 stars">
            {"★★★★★".split("").map((s) => <span>{s}</span>)}
          </div>
          <!-- Quote -->
          <blockquote class="flex-1 text-base leading-relaxed text-slate-700 italic">
            "{t.quote}"
          </blockquote>
          <!-- Attribution -->
          <footer class="mt-5 border-t border-slate-200 pt-4">
            <p class="text-sm font-bold text-funnel-text">— {t.name}</p>
            <p class="text-xs text-slate-500">{t.trade}, {t.location}</p>
          </footer>
        </div>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <FunnelCta text="Get Results Like These — Book a Call →" />
    </div>
  </div>
</section>
