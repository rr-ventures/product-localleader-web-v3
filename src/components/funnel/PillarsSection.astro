---
import FunnelCta from "./FunnelCta.astro";

const pillars = [
  {
    emoji: "📍",
    title: "Top of Google Maps",
    body: "When someone searches \"[your trade] near me,\" Google shows 3 businesses on the map. If you're not in those top 3, you're invisible. We get you there — and keep you there — so your phone rings from people ready to hire.",
  },
  {
    emoji: "🔍",
    title: "First Page of Google",
    body: "When locals search for your trade in your area, your business shows up first. Not your competitors. Not some directory. You. Organic traffic that comes to you every day without spending a cent on ads.",
  },
  {
    emoji: "⭐",
    title: "5-Star Review Engine",
    body: "We build you a system that generates real Google reviews from your happy customers — consistently, automatically. More reviews means more trust means more calls. You become the obvious choice before anyone even picks up the phone.",
  },
];
---

<section class="py-16 bg-funnel-light md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-funnel-text md:text-4xl">
        How We Make You the #1 Tradie in Your Area
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      {pillars.map((pillar) => (
        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition-shadow hover:shadow-md">
          <div class="mb-4 text-4xl" aria-hidden="true">{pillar.emoji}</div>
          <h3 class="text-xl font-bold text-funnel-primary mb-3">{pillar.title}</h3>
          <p class="text-sm leading-relaxed text-slate-600 flex-1">{pillar.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <FunnelCta text="See How It Works For Your Trade — Book a Call →" />
    </div>
  </div>
</section>
