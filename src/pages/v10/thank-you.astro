---
import Layout from "../../layouts/LayoutV10.astro";
import Header from "../../components/v10/Header.astro";
import Footer from "../../components/v10/Footer.astro";

const bookingPath = "/v10/#book-call";
---

<Layout title="Free Ranking Audit | Local Leader">
  <Header />
  <main class="pt-28 pb-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.32em] text-slate-500">Free ranking audit</p>
        <h1 class="mb-6 text-4xl font-serif text-slate-900 md:text-5xl">Tell us about your business</h1>
        <p class="mx-auto max-w-2xl text-lg leading-relaxed text-slate-600">
          Complete the quick audit request below. Once you submit it, we&apos;ll send you straight to the booking page so you can lock in your strategy call.
        </p>
      </div>

      <div class="overflow-hidden rounded-[2rem] border border-stone-200 bg-white p-3 shadow-[0_24px_60px_rgba(15,23,42,0.08)]">
        <div data-tf-live="01KMRRPWX1BV7SJ509RP03PCF7" class="min-h-[720px]"></div>
      </div>

      <div class="mt-6 text-center">
        <p class="text-sm text-slate-500">
          If the form does not load, <a href={bookingPath} class="font-medium text-slate-900 underline underline-offset-4">go straight to the booking section</a>.
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline src="//embed.typeform.com/next/embed.js"></script>
