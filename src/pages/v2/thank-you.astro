---
import LayoutV2 from '../../layouts/LayoutV2.astro';
import Header from '../../components/v2/Header.astro';
---

<LayoutV2 title="Thank You | Local Leader">
  <div class="min-h-screen flex flex-col relative overflow-hidden bg-[#FAFAFA]">
    <!-- Background blur effects -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] translate-x-1/3 -translate-y-1/4 pointer-events-none z-0 opacity-90">
      <img src="/images/hero-v2.jpg" alt="" class="w-full h-full object-cover rounded-full mix-blend-multiply filter blur-[60px]" />
    </div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] -translate-x-1/3 translate-y-1/3 pointer-events-none z-0 opacity-60">
      <img src="/images/hero-v2.jpg" alt="" class="w-full h-full object-cover rounded-full mix-blend-multiply filter blur-[80px]" />
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto w-full px-6 sm:px-12 lg:px-20 pt-8">
      <Header />
    </div>

    <main class="flex-grow flex items-center justify-center relative z-10 px-6 py-20">
      <div class="max-w-2xl w-full mx-auto text-center space-y-10">
        
        <div class="space-y-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-black text-white mb-4">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h1 class="text-5xl md:text-6xl font-bold font-serif tracking-tight text-gray-900">
            Request Received.
          </h1>
          <p class="text-xl text-gray-600 max-w-xl mx-auto leading-relaxed">
            We're preparing your Local Ranking Audit. While you wait, book your <strong class="text-gray-900">Free Strategy Call</strong> below to review the results together.
          </p>
        </div>

        <div class="bg-white/80 backdrop-blur-xl p-10 rounded-3xl shadow-xl border border-white/50 max-w-md mx-auto relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-black/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10 space-y-6">
            <svg class="w-12 h-12 mx-auto text-gray-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h2 class="text-2xl font-bold text-gray-900">Secure Your Time</h2>
            
            <a
              href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-8 py-4 bg-black text-white rounded-full font-medium hover:bg-gray-800 hover:scale-[1.02] transition-all shadow-lg"
            >
              Open Google Calendar
            </a>
          </div>
        </div>

        <div>
          <a href="/v2" class="text-gray-500 hover:text-black transition-colors font-medium">
            &larr; Return to homepage
          </a>
        </div>

      </div>
    </main>
  </div>
</LayoutV2>
