---
import LayoutV2 from '../../layouts/LayoutV2.astro';
import Header from '../../components/v2/Header.astro';
import Hero from '../../components/v2/Hero.astro';
import LogoCloud from '../../components/v2/LogoCloud.astro';
import HowItWorks from '../../components/v2/HowItWorks.astro';
import Pricing from '../../components/v2/Pricing.astro';
---

<LayoutV2 title="Local Leader | Become the #1 tradie in your area">
  <div class="min-h-screen flex flex-col relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[42rem] bg-[radial-gradient(circle_at_top_right,_rgba(45,212,191,0.24),_transparent_30%),radial-gradient(circle_at_15%_15%,_rgba(59,130,246,0.2),_transparent_24%),linear-gradient(180deg,_rgba(255,255,255,0.88),_rgba(248,249,250,0.5))] pointer-events-none z-0"></div>
    <div class="absolute right-[-12rem] top-[-7rem] h-[32rem] w-[32rem] rounded-full bg-teal-200/40 blur-3xl pointer-events-none z-0"></div>
    <div class="absolute left-[-10rem] top-[26rem] h-[24rem] w-[24rem] rounded-full bg-sky-200/35 blur-3xl pointer-events-none z-0"></div>
    <div class="absolute right-[14%] top-[7rem] hidden h-40 w-[38rem] rounded-full bg-gradient-to-r from-transparent via-cyan-200/40 to-transparent blur-3xl pointer-events-none z-0 lg:block"></div>
    <div class="absolute inset-0 bg-[radial-gradient(#cbd5e1_0.95px,transparent_0.95px)] [background-size:20px_20px] opacity-55 pointer-events-none z-0"></div>
    <div class="absolute inset-x-0 top-0 h-[38rem] bg-gradient-to-b from-white/60 via-white/10 to-transparent pointer-events-none z-0"></div>
    <div class="absolute top-0 right-0 w-[800px] h-[800px] translate-x-1/3 -translate-y-1/4 pointer-events-none z-0 opacity-25">
      <img src="/images/hero-v2.jpg" alt="" class="w-full h-full object-cover rounded-full mix-blend-multiply filter blur-[80px]" />
    </div>
    
    <div class="relative z-10 max-w-[1400px] mx-auto w-full px-6 sm:px-12 lg:px-20 pt-8 pb-24">
      <Header />
      <Hero />
      <LogoCloud />
      <HowItWorks />
      <Pricing />
    </div>
  </div>
</LayoutV2>
