---
import FunnelLayout from "../layouts/FunnelLayout.astro";
import HeroSection from "../components/funnel/HeroSection.astro";
import VslSection from "../components/funnel/VslSection.astro";
import ProblemSection from "../components/funnel/ProblemSection.astro";
import PillarsSection from "../components/funnel/PillarsSection.astro";
import TestimonialsSection from "../components/funnel/TestimonialsSection.astro";
import ComparisonSection from "../components/funnel/ComparisonSection.astro";
import QualifySection from "../components/funnel/QualifySection.astro";
import ProcessSection from "../components/funnel/ProcessSection.astro";
import FaqSection from "../components/funnel/FaqSection.astro";
import CalendarSection from "../components/funnel/CalendarSection.astro";
import FunnelFooter from "../components/funnel/FunnelFooter.astro";
---

<FunnelLayout
  title="Become the #1 Tradie in Your Area — Book a Free Strategy Call"
  description="Local Leader helps Australian trade businesses dominate Google Maps, rank first on Google Search, and build a 5-star review engine. Book your free 15-minute strategy call."
>
  <main>
    <!-- S1: Hero -->
    <HeroSection />

    <!--
      S7: VSL Section (hidden in v1)
      To activate: remove the `vsl-section--hidden` class in VslSection.astro
      This section sits here so it can be easily toggled on between Hero and Problem.
    -->
    <VslSection />

    <!-- S2: Problem Agitation -->
    <ProblemSection />

    <!-- S3: Three Pillars -->
    <PillarsSection />

    <!-- S4: Social Proof / Testimonials -->
    <TestimonialsSection />

    <!-- S5: Old Way vs. New Way -->
    <ComparisonSection />

    <!-- S6: Who It's For / Who It's Not For -->
    <QualifySection />

    <!-- S8: How It Works -->
    <ProcessSection />

    <!-- S9: FAQ -->
    <FaqSection />

    <!-- S10: Calendar Booking (all CTAs scroll here) -->
    <CalendarSection />
  </main>

  <!-- S11: Footer -->
  <FunnelFooter />
</FunnelLayout>
