---
import LayoutV1A from "../../layouts/LayoutV1A.astro";
import HeroV1A from "../../components/sections/HeroV1A.astro";
import TestimonialsV1A from "../../components/sections/TestimonialsV1A.astro";
import SolutionsV1A from "../../components/sections/SolutionsV1A.astro";
import PricingV1A from "../../components/sections/PricingV1A.astro";
import FAQV1A from "../../components/sections/FAQV1A.astro";
import CTAV1A from "../../components/sections/CTAV1A.astro";
---

<LayoutV1A
  title="Local Leader — Become the #1 Service Provider in Your Area"
  audience="business"
  basePath="/ranking"
  homePath="/ranking"
  thankYouPath="/ranking/thank-you"
>
  <main class="flex flex-col overflow-x-clip">
    <HeroV1A className="py-10 md:py-16" audience="business" thankYouPath="/ranking/thank-you" />
    <TestimonialsV1A className="py-10 md:py-16" audience="business" />
    <SolutionsV1A className="pt-10 md:pt-16" audience="business" />
    <PricingV1A className="py-10 md:py-16" audience="business" />
    <FAQV1A className="py-10 md:py-16" audience="business" />
    <CTAV1A className="py-10 md:py-16" audience="business" thankYouPath="/ranking/thank-you" />
  </main>
</LayoutV1A>
