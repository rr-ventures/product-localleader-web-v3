---
import LayoutV1A from "../layouts/LayoutV1A.astro";
import HeroV1A from "../components/sections/HeroV1A.astro";
import TestimonialsV1A from "../components/sections/TestimonialsV1A.astro";
import SolutionsV1A from "../components/sections/SolutionsV1A.astro";
import PricingV1A from "../components/sections/PricingV1A.astro";
import FAQV1A from "../components/sections/FAQV1A.astro";
import CTAV1A from "../components/sections/CTAV1A.astro";
---

<LayoutV1A
  title="Local Leader — Become the #1 Agent in Your Area"
  audience="agency"
  basePath="/agency"
  homePath="/agency"
  thankYouPath="/thank-you"
>
  <main class="flex flex-col overflow-x-clip">
    <HeroV1A className="py-10 md:py-16" audience="agency" thankYouPath="/thank-you" />
    <TestimonialsV1A className="py-10 md:py-16" audience="agency" />
    <SolutionsV1A className="pt-10 md:pt-16" audience="agency" />
    <PricingV1A className="py-10 md:py-16" audience="agency" />
    <FAQV1A className="py-10 md:py-16" audience="agency" />
    <CTAV1A className="py-10 md:py-16" audience="agency" thankYouPath="/thank-you" />
  </main>
</LayoutV1A>
