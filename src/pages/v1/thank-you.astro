---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/shared/Container.astro';
import Title from '../../components/shared/Title.astro';
import Paragraph from '../../components/shared/Paragraph.astro';
import GradiantText from '../../components/shared/GradiantText.astro';
---

<Layout title="Thank You | Local Leader">
  <main class="flex flex-col gap-y-20 md:gap-y-32 overflow-hidden pt-32 pb-20">
    <section class="relative">
      <Container className="flex flex-col items-center text-center max-w-3xl mx-auto space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 text-emerald-700 font-medium text-sm border border-emerald-200">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Request Received
        </div>
        
        <Title>
          You're one step closer to <GradiantText>dominating your local area.</GradiantText>
        </Title>
        
        <Paragraph className="text-lg md:text-xl">
          We've received your request for a Local Ranking Audit. While we prepare your custom report, <strong>book your Free Strategy Call below</strong> to go over the results and map out your growth plan.
        </Paragraph>

        <div class="w-full max-w-md mx-auto mt-8 p-8 bg-white rounded-3xl shadow-xl border border-gray-100 flex flex-col items-center gap-6">
          <div class="w-16 h-16 bg-blue-50 text-primary rounded-2xl flex items-center justify-center mb-2">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900">Book Your Strategy Call</h3>
          <p class="text-gray-600">Choose a time that works for you to discuss your audit and strategy.</p>
          
          <a
            href="https://calendar.app.google/ceK9b3Jr3KGD9cCs5"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full px-8 py-4 bg-primary text-white text-lg font-bold rounded-full hover:bg-[#172554] hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 ease-in-out text-center"
          >
            Open Google Calendar
          </a>
        </div>
        
        <a href="/v1" class="text-primary hover:underline mt-8 inline-block font-medium">
          &larr; Back to home
        </a>
      </Container>
    </section>
  </main>
</Layout>
