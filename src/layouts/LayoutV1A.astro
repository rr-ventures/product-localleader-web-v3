---
import NavbarV1A from "./NavbarV1A.astro";
import FooterV1A from "./FooterV1A.astro";

export interface Props {
  title: string;
  audience?: "tradie" | "business";
  basePath?: string;
  homePath?: string;
  thankYouPath?: string;
}

const {
  title,
  audience = "tradie",
  basePath = "",
  homePath = "/",
  thankYouPath = "/thank-you",
} = Astro.props;
---

<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-512.png" />
    <link rel="apple-touch-icon" href="/favicon-512.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Local Leader helps Australian local businesses dominate Google Maps, rank higher on Google Search, and build a 5-star review engine. No lock-in."
    />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style/custom.css" />
  </head>
  <body class="overflow-hidden overflow-y-auto bg-body">
    <NavbarV1A basePath={basePath} homePath={homePath} />
    <slot />
    <FooterV1A
      basePath={basePath}
      homePath={homePath}
      thankYouPath={thankYouPath}
      audience={audience}
    />
  </body>
  <script>
    document.documentElement.classList.remove("dark");
    localStorage.setItem("theme", "light");
  </script>
  <script>
    const toggleMenu = document.querySelector(
      "[data-toggle-nav]"
    ) as HTMLButtonElement;
    const navbar = document.querySelector("[data-navbar]") as HTMLDivElement;
    const overlayNav = document.querySelector(
      "[data-nav-overlay]"
    ) as HTMLDivElement;
    if (toggleMenu) {
      toggleMenu.addEventListener("click", (e) => {
        e.preventDefault();
        if (toggleMenu.getAttribute("data-open-nav") === "false") {
          toggleMenu.setAttribute("data-open-nav", "true");
          overlayNav.setAttribute("data-is-visible", "true");
          document.body.classList.add("!overflow-y-hidden");
          navbar.style.height = `${navbar.scrollHeight}px`;
        } else {
          toggleMenu.setAttribute("data-open-nav", "false");
          overlayNav.setAttribute("data-is-visible", "false");
          document.body.classList.remove("!overflow-y-hidden");
          navbar.style.height = "0px";
        }
      });

      navbar.addEventListener("click", () => {
        toggleMenu.setAttribute("data-open-nav", "false");
        overlayNav.setAttribute("data-is-visible", "false");
        document.body.classList.remove("!overflow-y-hidden");
        navbar.style.height = "0px";
      });

      overlayNav.addEventListener("click", () => {
        toggleMenu.setAttribute("data-open-nav", "false");
        overlayNav.setAttribute("data-is-visible", "false");
        document.body.classList.remove("!overflow-y-hidden");
        navbar.style.height = "0px";
      });
    }
  </script>
</html>
