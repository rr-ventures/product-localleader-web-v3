---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-AU" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Local Leader version 10 - Local SEO for Australian service providers."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#f7f4ee] text-slate-900 antialiased selection:bg-slate-900 selection:text-white">
    <div class="fixed inset-0 z-[-3] bg-[linear-gradient(180deg,rgba(255,255,255,0.82),rgba(247,244,238,0.96))] pointer-events-none"></div>
    <div class="fixed inset-0 z-[-2] bg-[radial-gradient(circle_at_top_right,rgba(148,163,184,0.18),transparent_26%),radial-gradient(circle_at_18%_12%,rgba(226,232,240,0.7),transparent_22%)] pointer-events-none"></div>
    <div class="fixed inset-0 z-[-1] bg-[radial-gradient(#d6d3d1_0.8px,transparent_0.8px)] [background-size:22px_22px] opacity-40 pointer-events-none"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: "Inter", system-ui, sans-serif;
    --font-serif: "Playfair Display", Georgia, serif;
  }

  html {
    font-family: var(--font-sans);
  }

  .font-serif {
    font-family: var(--font-serif);
  }
</style>
